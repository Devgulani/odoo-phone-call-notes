<?xml version="1.0" encoding="UTF-8"?>

<odoo>
    
    <record id ="view_phone_call_wizard_form" model="ir.ui.view">

        <field name = "name">phone.call.wizard.form</field>

        <field name = "model">phone.call.wizard</field>

        <field name = "arch" type = "xml">
        
            <form string = "Call Contact">

                <group>

                    <field name="partner_id"/>

                    <field name="phone"/>

                    <field name="status"/>

                    <field name="notes"/>

                </group>
                
                <footer>

                    <button
                        name = "action_save_call"
                        string = "Save"
                        type = "object"
                        class = "btn-primary"/>

                    <button
                        string= "Cancel"
                        special= "cancel"/>


                </footer>

            </form>

        </field>

    </record>

</odoo>